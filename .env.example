# =========================================
# VARIÁVEIS DE AMBIENTE — copie este arquivo
# como .env.local para desenvolvimento local.
#
# No Vercel, adicione cada uma delas em:
# Settings → Environment Variables
# =========================================

# --- Firebase ---
# Firebase Console → Configurações do projeto → Seus apps → Config
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# --- IGDB (Twitch Developer) ---
# Crie em: https://dev.twitch.tv/console/apps
# Essas duas ficam APENAS no servidor (Vercel), nunca com prefixo VITE_
IGDB_CLIENT_ID=
IGDB_CLIENT_SECRET=
